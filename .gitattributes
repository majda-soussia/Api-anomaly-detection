# Auto detect text files and normalize line endings to LF
* text=auto

# Notebooks (keep LF)
*.ipynb text eol=lf
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.csv text eol=lf

# Binary files
*.keras binary
*.h5 binary
*.pkl binary
*.npy binary
*.png binary
*.jpg binary
